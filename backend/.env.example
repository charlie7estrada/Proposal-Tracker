# Copy this file to backend/.env and fill in real values. Never commit .env.

# Required. Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional overrides (sensible dev defaults are used when unset)
# DATABASE_URL=postgresql://user:password@localhost:5432/proposal_tracker
# FRONTEND_ORIGIN=http://localhost:3100
# UPLOAD_DIR=/absolute/path/for/uploads
# MAX_UPLOAD_MB=10
# PORT=5000
# FLASK_DEBUG=1
